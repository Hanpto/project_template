{
  "template_version": "1.0.0",
  "platform": "ios",
  "upstream": {
    "repo": "Hanpto/project_template",
    "path": "ios/MyApplication",
    "pinned_commit": ""
  },
  "injection_points": [
    {
      "name": "GeneratedView.swift",
      "path": "MyApplication/Generated/GeneratedView.swift",
      "placeholder": true,
      "replace_mode": "overwrite"
    }
  ],
  "auto_run_flows": {
    "anchor_start_then_end": {
      "entry": "MyApplication/AutoRun/AnchorStartThenEnd.swift",
      "description": "启动 → 自动登录 → 进入主播视图 → 开播 → 30s 后结束 → 退出",
      "timeout_sec": 60
    }
  }
}
